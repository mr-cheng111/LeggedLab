<?xml version='1.0' encoding='utf-8'?>
<!--
  Isaac Lab actuated URDF notes for RB160W / Astrall A01 engineering model.

  Mesh paths were converted from ROS package URIs to relative paths so the
  Isaac Lab URDF converter can resolve them from this file location.

  Joint limits and actuator limits are based on the SDK document provided with
  this repository:
    - Hip range:   +/-15 deg  = +/-0.261799 rad
    - Thigh range: +/-170 deg = +/-2.967060 rad
    - Calf range:  +/-148 deg = +/-2.583087 rad
    - Rated torque: 50 N*m
    - Peak torque:  300 N*m
    - Rated speed:  100 rpm +/-10%

  This URDF uses the peak torque, 300 N*m, as the joint effort limit and uses
  the upper speed tolerance, 110 rpm = 11.519173 rad/s, as the velocity limit.
  Long-duration control in Isaac Lab should normally scale actions or actuator
  limits closer to the rated 50 N*m value instead of continuously relying on
  peak torque.

  Wheel joints are modeled as continuous joints and currently use the same
  effort and velocity limits as the leg motors. Replace these values if a
  separate wheel motor specification is available.

  Tire/foot-ground friction is intentionally not encoded here. Configure
  PhysX/Isaac Lab rigid body or terrain physics materials in the simulation
  config instead. Conservative starting values:
    - static_friction:  1.2
    - dynamic_friction: 1.0
    - restitution:      0.0

  For reinforcement learning, consider friction randomization:
    - static_friction:  0.8 to 1.6
    - dynamic_friction: 0.6 to 1.3
-->
<robot name="RB160W">
  <link name="base_link">
    <inertial>
      <origin xyz="-0.0085 0 -0.0377" rpy="0 0 0" />
      <mass value="42.0639" />
      <inertia ixx="0.516" ixy="0.0008" ixz="0.0248" iyy="1.7809" iyz="-0.0006" izz="1.9712" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../meshes/base_link.STL" />
      </geometry>
      <material name="silver">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>
  <link name="FR_hip">
    <inertial>
      <origin xyz="0.0647 -0.0402 0" rpy="0 0 0" />
      <mass value="2.4" />
      <inertia ixx="0.0054" ixy="0.0015" ixz="0" iyy="0.0068" iyz="0" izz="0.0069" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../meshes/FR_hip.STL" />
      </geometry>
      <material name="silver">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../meshes/FR_hip.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="FR_hip_joint" type="revolute">
    <origin xyz="0.249 -0.1 -0.0666" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="FR_hip" />
    <axis xyz="-1 0 0" />
    <limit lower="-0.261799" upper="0.261799" effort="300" velocity="11.519173" />
  </joint>
  <link name="FR_thigh">
